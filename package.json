{
  "name": "@hemocode/pi-model-selector",
  "version": "1.0.0",
  "description": "A Pi extension that automatically selects the best model based on remaining usage quotas across various providers (Claude, OpenAI, Gemini, etc.).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CTristan/pi-model-selector.git"
  },
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "src/",
    "config/model-selector.example.json",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@mariozechner/pi-coding-agent": "latest",
    "@types/luxon": "3.7.1",
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "4.1.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "scripts": {
    "type-check": "tsc",
    "check": "biome check .",
    "fix": "biome check --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "./scripts/ci.sh",
    "setup-hooks": "./scripts/setup-hooks.sh",
    "prepare": "node scripts/prepare.js"
  },
  "dependencies": {
    "luxon": "^3.7.2"
  }
}
